{
  "name": "chat-browser",
  "version": "0.1.1",
  "description": "Browse, search, and analyze CLI chat sessions from Claude Code, GitHub Copilot CLI, and OpenAI Codex CLI",
  "type": "module",
  "bin": {
    "chat-browser": "./bin/run.js"
  },
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "prepublishOnly": "npm run build",
    "start": "node --experimental-sqlite --no-warnings bin/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "bin/",
    "lib/",
    "dist/"
  ],
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "marked": "^18.0.0",
    "open": "^10.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "recharts": "^2.15.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
